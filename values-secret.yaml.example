# Sensitive overrides template.
ragflow:
  service_conf:
    user_default_llm:
      # Update these for your inference provider.
      api_key: "CHANGEME_LLM_API_KEY"
      base_url: "https://api.example.com/api/v1"
      default_models:
        chat_model:
          name: "CHANGEME_CHAT_MODEL"
        embedding_model:
          name: "CHANGEME_EMBEDDING_MODEL"
        rerank_model: "CHANGEME_RERANK_MODEL"
        asr_model:
          name: "CHANGEME_ASR_MODEL"
        image2text_model:
          name: "CHANGEME_VLM_MODEL"
    oauth:
      oidc:
        # Update these for your identity provider.
        display_name: "Example Identity Provider"
        client_id: "ragflow.example.com"
        client_secret: "CHANGEME"
        issuer: "https://idp.example.com"
        scope: "openid email profile"
        redirect_uri: "https://ragflow.example.com/v1/user/oauth/callback/oidc"
